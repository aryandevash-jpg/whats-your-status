{
  "name": "whats-your-status",
  "version": "1.0.0",
  "private": true,
  "description": "Asynchronous SEO + GEO analysis with LLM recommendations",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:ci": "JEST_JUNIT_OUTPUT_DIR=reports JEST_JUNIT_OUTPUT_NAME=junit.xml jest --ci --reporters=default --reporters=jest-junit",
    "start:api": "node dist/api/server.js",
    "start:worker": "node dist/queue/worker.js",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:worker": "tsx watch src/queue/worker.ts",
    "dev:web": "npm run dev --prefix web",
    "build:web": "npm run build --prefix web"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/static": "^9.1.3",
    "@google/generative-ai": "^0.21.0",
    "axios": "^1.7.9",
    "bullmq": "^5.34.3",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
