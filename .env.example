# Copy to .env and fill in values:
#   cp .env.example .env

# Redis (BullMQ + job store + cache). Default if omitted: redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# PageSpeed Insights API (use one)
PAGESPEED_API_KEY=
# GOOGLE_API_KEY=

# Google Gemini (AI Studio)
GEMINI_API_KEY=
# Optional model id (default: gemini-2.5-flash). Examples: gemini-2.5-flash-lite, gemini-3-flash-preview
# GEMINI_MODEL=

# HTTP server (optional)
PORT=3000
HOST=0.0.0.0

# CORS for the Vite app (comma-separated origins). Omit to allow any origin (local dev).
# CORS_ORIGIN=http://localhost:5173

# PageSpeed: base read timeout (ms), max per attempt, multiplier each retry (slow sites get longer waits).
# PAGESPEED_TIMEOUT_MS=180000
# PAGESPEED_TIMEOUT_MAX_MS=300000
# PAGESPEED_TIMEOUT_RETRY_MULTIPLIER=1.35
# PageSpeed HTTP retries (ECONNRESET / 429 / 5xx): retry until wall-clock budget; connection drops use a short delay.
# PAGESPEED_HTTP_RETRY_BUDGET_MS=900000
# PAGESPEED_HTTP_MAX_TRIES=40
# PAGESPEED_HTTP_RETRY_BASE_MS=1000
# SCRAPE_TIMEOUT_MS=30000
# GEMINI_TIMEOUT_MS=60000

# Worker: concurrent BullMQ jobs per process (each runs PageSpeed). Default 1.
# WORKER_CONCURRENCY=1
# BullMQ job lock (ms); must exceed slow PageSpeed retries. Default 30m.
# WORKER_LOCK_DURATION_MS=1800000

# Optional: set to "debug" for verbose logs
# LOG_LEVEL=debug
