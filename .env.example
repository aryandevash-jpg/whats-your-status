# Copy to .env and fill in values:
#   cp .env.example .env

# Redis (BullMQ + job store + cache). Default if omitted: redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379

# PageSpeed Insights API (use one)
PAGESPEED_API_KEY=
# GOOGLE_API_KEY=

# Google Gemini (AI Studio)
GEMINI_API_KEY=

# HTTP server (optional)
PORT=3000
HOST=0.0.0.0

# Optional: set to "debug" for verbose logs
# LOG_LEVEL=debug
